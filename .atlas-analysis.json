  "keyFeatures": [
    "Real-time messaging with Socket.io WebSockets",
    "JWT-based user authentication with email verification",
    "Friend request system with search, accept, and reject flows",
    "Typing indicators and message read receipts",
    "Online/offline presence tracking",
    "Image upload support via Cloudinary",
    "Responsive UI with dark/light mode using Tailwind CSS and Shadcn UI",
    "Redux state management with React Query for data fetching"
  ],
  "publicApiSurface": [
    "POST /api/auth/signup",
